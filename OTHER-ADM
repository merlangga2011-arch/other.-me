    local buttonFrame = Instance.new("Frame")
    buttonFrame.Size = UDim2.new(0, 270, 0, 35)
    buttonFrame.Position = UDim2.new(1, -280, 0.5, -17.5)
    buttonFrame.BackgroundTransparency = 1
    buttonFrame.Parent = entryFrame
    
    local commands = {"view", "unview", "explode", "bring", "to"}
    local btnNames = {"VIEW", "UNVIEW", "EXP", "BRING", "TO"}
    
    for i, cmd in ipairs(commands) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 48, 0, 32)
        btn.Position = UDim2.new((i-1) * 0.18, 0, 0, 0)
        btn.BackgroundColor3 = Color3.fromRGB(80, 80, 100)
        btn.Text = btnNames[i]
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 9
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Parent = buttonFrame
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 5)
        btnCorner.Parent = btn
        
        btn.MouseButton1Click:Connect(function()
            local success = executePlayerCommand(player, cmd)
            if success then
                btn.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
                task.wait(0.15)
                btn.BackgroundColor3 = Color3.fromRGB(80, 80, 100)
            else
                btn.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
                task.wait(0.15)
                btn.BackgroundColor3 = Color3.fromRGB(80, 80, 100)
            end
        end)
    end
    
    return entryFrame
end

local function updatePlayerList(filter)
    for _, entry in pairs(playerEntries) do
        if entry then
            entry:Destroy()
        end
    end
    playerEntries = {}
    
    local players = Players:GetPlayers()
    local filtered = {}
    
    for _, player in ipairs(players) do
        if player ~= LocalPlayer then
            if filter == "" or player.DisplayName:lower():find(filter) or player.Name:lower():find(filter) then
                table.insert(filtered, player)
            end
        end
    end
    
    table.sort(filtered, function(a, b)
        return a.DisplayName < b.DisplayName
    end)
    
    totalLabel.Text = "TOTAL: " .. #filtered .. " / " .. (#players - 1)
    
    local yPos = 0
    for _, player in ipairs(filtered) do
        local entry = createPlayerEntry(player, yPos)
        table.insert(playerEntries, entry)
        yPos = yPos + 55
    end
    
    playerList.CanvasSize = UDim2.new(0, 0, 0, yPos + 10)
end

searchBox:GetPropertyChangedSignal("Text"):Connect(function()
    currentFilter = searchBox.Text:lower()
    updatePlayerList(currentFilter)
end)

ToggleBtn.MouseButton1Click:Connect(function()
    isOpen = not isOpen
    MainFrame.Visible = isOpen
    if isOpen then
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(80, 180, 80)
        updatePlayerList(currentFilter)
    else
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    end
end)

CloseBtn.MouseButton1Click:Connect(function()
    isOpen = false
    MainFrame.Visible = false
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    searchBox.Text = ""
end)

UserInputService.TouchTap:Connect(function(touchPos, gameProcessed)
    if not gameProcessed and not isOpen then
        local btnPos = ToggleBtn.AbsolutePosition
        local btnSize = ToggleBtn.AbsoluteSize
        local touchInBtn = (touchPos.X >= btnPos.X and touchPos.X <= btnPos.X + btnSize.X and
                           touchPos.Y >= btnPos.Y and touchPos.Y <= btnPos.Y + btnSize.Y)
        if touchInBtn then
            isOpen = true
            MainFrame.Visible = true
            ToggleBtn.BackgroundColor3 = Color3.fromRGB(80, 180, 80)
            updatePlayerList(currentFilter)
        end
    end
end)

updatePlayerList(currentFilter)
