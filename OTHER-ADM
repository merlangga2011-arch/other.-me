local Event = ReplicatedStorage:FindFirstChild("HDAdminHDClient")
local Remote = nil
if Event and Event:FindFirstChild("Signals") and Event.Signals:FindFirstChild("RequestCommandSilent") then
    Remote = Event.Signals.RequestCommandSilent
end

local function sendCommand(cmd)
    if Remote then
        return Remote:InvokeServer(cmd)
    end
    return false
end

local function executePlayerCommand(player, cmd)
    if not player then return false end
    local username = player.Name
    local Result = sendCommand(";" .. cmd .. " " .. username)
    return Result == true
end

local function createPlayerEntry(player, yPos)
    local entryFrame = Instance.new("Frame")
    entryFrame.Size = UDim2.new(1, -10, 0, 45)
