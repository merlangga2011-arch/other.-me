local function updateTrollCommandList()
    for _, child in pairs(trollCommandPanel:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    local yPos = 0
    for i, cmd in ipairs(allCommands) do
        local row = math.floor((i-1) / 3)
        local col = (i-1) % 3
        
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 105, 0, 30)
        btn.Position = UDim2.new(0, 5 + (col * 110), 0, yPos)
        btn.BackgroundColor3 = Color3.fromRGB(80, 70, 60)
        btn.Text = cmd
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 10
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Parent = trollCommandPanel
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 5)
        btnCorner.Parent = btn
        
        btn.MouseButton1Click:Connect(function()
            if trollTarget then
                local success = executeTrollCommand(cmd)
                if success then
                    btn.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
                    task.wait(0.15)
                    btn.BackgroundColor3 = Color3.fromRGB(80, 70, 60)
                else
                    btn.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
                    task.wait(0.15)
                    btn.BackgroundColor3 = Color3.fromRGB(80, 70, 60)
                end
            else
                btn.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
                task.wait(0.2)
                btn.BackgroundColor3 = Color3.fromRGB(80, 70, 60)
            end
        end)
        
        if col == 2 then
            yPos = yPos + 40
        end
    end
    
    local rows = math.ceil(#allCommands / 3)
    trollCommandPanel.CanvasSize = UDim2.new(0, 0, 0, rows * 45 + 10)
end

