local Event = ReplicatedStorage:FindFirstChild("HDAdminHDClient")
local Remote = nil
if Event and Event:FindFirstChild("Signals") and Event.Signals:FindFirstChild("RequestCommandSilent") then
    Remote = Event.Signals.RequestCommandSilent
end

local function sendCommand(cmd)
    if Remote then
        return Remote:InvokeServer(cmd)
    end
    return false
end

local function executeCmdBar2()
    local Event = ReplicatedStorage:FindFirstChild("HDAdminHDClient")
    if Event and Event:FindFirstChild("Signals") and Event.Signals:FindFirstChild("ExecuteClientCommand") then
        local remote = Event.Signals.ExecuteClientCommand
        firesignal(remote.OnClientEvent, 
            {
                game:GetService("Players").LocalPlayer,
                {
                    game:GetService("Players").LocalPlayer
                },
                "cmdbar2",
                {
                    FromClient = false,
                    UnFunction = false
                }
            }
        )
        return true
    end
    return false
end

