local function updateOtherList(filter)
    for _, entry in pairs(otherEntries) do
        if entry then
            entry:Destroy()
        end
    end
    otherEntries = {}
    
    local players = Players:GetPlayers()
    local filtered = {}
    
    for _, player in ipairs(players) do
        if player ~= LocalPlayer then
            if filter == "" or player.DisplayName:lower():find(filter) or player.Name:lower():find(filter) then
                table.insert(filtered, player)
            end
        end
    end
    
    table.sort(filtered, function(a, b)
        return a.DisplayName < b.DisplayName
    end)
    
    otherTotalLabel.Text = "TOTAL: " .. #filtered .. " / " .. (#players - 1)
    
    local yPos = 0
    for _, player in ipairs(filtered) do
        local entry = createOtherEntry(player, yPos)
        table.insert(otherEntries, entry)
        yPos = yPos + 55
    end
    
    otherPlayerList.CanvasSize = UDim2.new(0, 0, 0, yPos + 10)
end

